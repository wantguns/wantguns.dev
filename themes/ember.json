{
  "name": "ember",
  "displayName": "Ember",
  "type": "dark",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#d9d9d9",
    "editor.selectionBackground": "#333333",
    "editor.lineHighlightBackground": "#0d0d0d",
    "editorCursor.foreground": "#d9d9d9",
    "editorWhitespace.foreground": "#222222"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#404040"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#737373"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#595959"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#d9d9d9"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#b3b3b3"
      }
    },
    {
      "scope": ["variable"],
      "settings": {
        "foreground": "#d9d9d9"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#595959"
      }
    },
    {
      "scope": ["storage"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["storage.type"],
      "settings": {
        "foreground": "#e78a53",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type"],
      "settings": {
        "foreground": "#d9d9d9"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#b3b3b3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#d9d9d9"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#b3b3b3"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#b3b3b3"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#b3b3b3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.function"],
      "settings": {
        "foreground": "#d9d9d9"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["support.type", "support.class"],
      "settings": {
        "foreground": "#e78a53",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.other.variable"],
      "settings": {
        "foreground": "#b3b3b3"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#595959"
      }
    },
    {
      "scope": ["punctuation.definition.string"],
      "settings": {
        "foreground": "#595959"
      }
    },
    {
      "scope": ["meta.separator"],
      "settings": {
        "foreground": "#595959"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#000000",
        "background": "#737373"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#000000",
        "background": "#e78a53"
      }
    }
  ]
}
