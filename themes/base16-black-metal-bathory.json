{
  "name": "base16-black-metal-bathory",
  "displayName": "Base16 Black Metal Bathory",
  "type": "dark",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#c1c1c1",
    "editor.selectionBackground": "#222222",
    "editor.lineHighlightBackground": "#121212",
    "editorCursor.foreground": "#c1c1c1",
    "editorWhitespace.foreground": "#333333"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#888888"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#fbcb97"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["constant.character", "constant.other"],
      "settings": {
        "foreground": "#aaaaaa"
      }
    },
    {
      "scope": ["variable"],
      "settings": {
        "foreground": "#5f8787"
      }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.operator"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["storage"],
      "settings": {
        "foreground": "#fbcb97"
      }
    },
    {
      "scope": ["storage.type"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5f8787"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type"],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "fontStyle": "italic underline",
        "foreground": "#fbcb97"
      }
    },
    {
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#fbcb97"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5f8787"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#5f8787"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["support.function"],
      "settings": {
        "foreground": "#fbcb97"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#e78a53"
      }
    },
    {
      "scope": ["support.type", "support.class"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5f8787"
      }
    },
    {
      "scope": ["support.other.variable"],
      "settings": {
        "foreground": "#5f8787"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#000000",
        "background": "#5f8787"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#000000",
        "background": "#e78a53"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#c1c1c1"
      }
    },
    {
      "scope": ["meta.separator"],
      "settings": {
        "foreground": "#999999"
      }
    }
  ]
}
